# Copy this file to .env and fill in your API keys.
# You need at least ONE provider configured (Anthropic recommended for vision).

# Anthropic (recommended — best vision + structured output)
ANTHROPIC_API_KEY=

# OpenAI (fallback + text-native PDFs)
OPENAI_API_KEY=

# Groq (fast text-only classification; no vision)
GROQ_API_KEY=

# Provider selection (optional; sensible defaults chosen if unset)
# VISION_PROVIDER=anthropic   # anthropic | openai
# TEXT_PROVIDER=openai        # openai | anthropic | groq

# Model overrides (optional)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# OPENAI_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.3-70b-versatile

# LangSmith (optional — engineering-level tracing for LLM calls + graph nodes)
# When LANGSMITH_TRACING=true and LANGSMITH_API_KEY is set, every LLM call and
# graph-node run is sent to LangSmith under the given project. The local
# FinalDecision.trace is unaffected; LangSmith is purely additive.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=plum-claims-dev
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
